# ============ ОБЯЗАТЕЛЬНЫЕ (всего 4) ============

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Ссылка на сайт (без слэша в конце)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Supabase → Settings → API (там же лежит база данных — без неё негде
# хранить пользователей, звёзды и инвентарь)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Service role key — ТОЛЬКО серверный, никогда не выносить в NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============ НЕОБЯЗАТЕЛЬНЫЕ ============

# Доп. защита вебхука (если задать — добавьте &secret_token=... в setWebhook)
# BOT_WEBHOOK_SECRET=

# Свой ключ подписи cookie (по умолчанию выводится из токена бота)
# SESSION_SECRET=
